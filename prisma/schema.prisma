// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Core Models
// ============================================================================

model Account {
  id                String    @id @default(cuid())
  createdOn         DateTime?
  accessedOn        DateTime?
  createdFromIp     String?
  lastAccessedFromIp String?
  registered        Boolean   @default(false)
  accountType       String    // 'brand' | 'individual' | 'dependent' | 'guest'
  name              String?
  location          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  conversations     Conversation[]
  activities        Activity[]
  preferences       UserPreference?
  blogs             Blog[]

  @@map("accounts")
}

// ============================================================================
// Messaging & Communication
// ============================================================================

model Conversation {
  id                    String    @id @default(cuid())
  accountId             String?
  customerName          String
  customerPhone         String
  customerEmail         String?
  customerAvatarUrl     String?
  notes                 String?
  assignedTo            String    @default("AI Assistant")
  subject               String
  lastMessageAt         DateTime  @default(now())
  lastMessageSnippet    String?
  lastMessageSender     String    @default("agent") // agent | customer
  isRead                Boolean   @default(true)
  leadCategory          String    @default("New Inquiry") // New Inquiry | Follow-up | Negotiation | General Question | Other
  leadScore             Int       @default(5) // 1-10
  aiInterventionActive  Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  account               Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  messages              Message[]

  @@index([accountId])
  @@index([customerPhone])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id                String    @id @default(cuid())
  conversationId    String
  sender            String    // agent | customer
  text              String
  timestamp         DateTime  @default(now())

  // Relations
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([timestamp])
  @@map("messages")
}

// ============================================================================
// Content Management
// ============================================================================

model FAQ {
  id        String    @id @default(cuid())
  question  String
  answer    String
  category  String    @default("General") // General | Buying | Selling | Renting | Technical
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([category])
  @@index([createdAt])
  @@map("faqs")
}

model Blog {
  id                String    @id @default(cuid())
  title             String
  slug              String    @unique
  content           String
  excerpt           String?
  featuredImageUrl  String?
  authorId          String
  authorName        String
  authorAvatarUrl   String?
  tags              String[]  @default([])
  status            String    @default("draft") // draft | published
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  publishedAt       DateTime?

  // Relations
  author            Account   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([slug])
  @@index([status])
  @@index([createdAt])
  @@map("blogs")
}

model SiteContent {
  id        String    @id @default(cuid())
  key       String    @unique
  value     String
  section   String?   // footer | header | about | home | etc.
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([section])
  @@map("site_content")
}

// ============================================================================
// User Activity & Preferences
// ============================================================================

model Activity {
  id          String    @id @default(cuid())
  accountId   String
  activity    String    // page_view | save_property | view | save | share | call | inquiry | visit_request | mortgage_request
  page        String?
  propertyId  String?
  activityOn  DateTime  @default(now())
  duration    Int?      // in seconds

  // Relations
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([activityOn])
  @@index([propertyId])
  @@map("activities")
}

model UserPreference {
  id                        String    @id @default(cuid())
  accountId                 String    @unique
  updatedAt                 DateTime  @updatedAt
  
  // Preference aggregates (flexible JSON structure)
  preferences               Json      @default("{}")
  
  // Counters
  totalViews                Int       @default(0)
  totalSaves                Int       @default(0)
  totalCalls                Int       @default(0)
  totalInquiries            Int       @default(0)
  totalVisitRequests        Int       @default(0)
  totalMortgageRequests     Int       @default(0)
  totalShares               Int       @default(0)
  totalTimeSpentInSeconds   Int       @default(0)

  // Relations
  account                   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("user_preferences")
}

// ============================================================================
// Requests & Inquiries
// ============================================================================

model PropertyRequest {
  id            String    @id @default(cuid())
  name          String
  email         String
  phone         String?
  location      String?
  propertyType  String?
  bedrooms      Int?
  bathrooms     Int?
  budget        Int?
  remarks       String?
  status        String    @default("new") // new | contacted | closed
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("property_requests")
}

model MortgageRequest {
  id              String    @id @default(cuid())
  name            String
  email           String
  phone           String
  address         String
  age             Int
  income          Int
  moreDetails     String?
  contactMethods  String[]  @default([]) // call | email | whatsapp
  status          String    @default("new") // new | contacted | in-progress | closed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("mortgage_requests")
}

model SalesRequest {
  id                String    @id @default(cuid())
  name              String
  email             String
  phone             String
  propertyLocation  String
  propertyType      String
  remarks           String?
  status            String    @default("new") // new | contacted | closed
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("sales_requests")
}

model VisitRequest {
  id              String    @id @default(cuid())
  propertyId      String
  propertyTitle   String
  agentId         String
  agentName       String
  name            String
  email           String
  phone           String?
  preferredDate   String    // YYYY-MM-DD
  preferredTime   String?   // HH:mm
  status          String    @default("new") // new | confirmed | completed | cancelled
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([propertyId])
  @@index([agentId])
  @@index([status])
  @@index([createdAt])
  @@map("visit_requests")
}

// ============================================================================
// Error & System Logging
// ============================================================================

model Problem {
  id        String    @id @default(cuid())
  context   String
  message   String
  stack     String?
  details   Json?
  createdAt DateTime  @default(now())

  @@index([createdAt])
  @@map("problems")
}

// ============================================================================
// Newsletter
// ============================================================================

model NewsletterSubscription {
  id        String    @id @default(cuid())
  email     String    @unique
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("newsletter_subscriptions")
}

// ============================================================================
// Sitemaps & SEO
// ============================================================================

model SitemapEntry {
  id        String    @id @default(cuid())
  url       String    @unique
  priority  Float     @default(0.5)
  frequency String    @default("weekly") // always | hourly | daily | weekly | monthly | yearly | never
  lastmod   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([url])
  @@map("sitemaps")
}

// ============================================================================
// Property Catalog (from existing schema)
// ============================================================================

model Property {
  id              String    @id @default(cuid())
  title           String?
  description     String?
  price           Int?
  status          String?
  isFeatured      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([price])
  @@map("properties")
}

// ============================================================================
// Agency References (from existing adapter pattern)
// ============================================================================

model Agency {
  id              String    @id @default(cuid())
  name            String
  description     String?
  contactEmail    String?
  contactPhone    String?
  website         String?
  logoUrl         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("agencies")
}

model Agent {
  id              String    @id @default(cuid())
  name            String
  email           String?
  phone           String?
  agencyId        String?
  bio             String?
  avatarUrl       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([agencyId])
  @@map("agents")
}

model Team {
  id              String    @id @default(cuid())
  name            String
  description     String?
  imageUrl        String?
  position        Int?      // For ordering
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("teams")
}

model Requirement {
  id              String    @id @default(cuid())
  userId          String
  minBudget       Int?
  maxBudget       Int?
  location        String?
  propertyType    String[]  @default([])
  purpose         String?   // 'Sale' | 'Rent' | 'Lease'
  urgency         String?   // 'within a month' | 'within 3 months' | etc.
  requiredTime    String?   // same as urgency
  paymentMethod   String[]  @default([])
  loan            Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@map("requirements")
}
