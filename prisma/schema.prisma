// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Core Models
// ============================================================================

model Account {
  id                String    @id @default(cuid())
  registered        Boolean   @default(false)
  accountType       String    // 'brand' | 'individual' | 'dependent' | 'guest'

  // Relations
  conversations     Conversation[]
  activities        Activity[]
  preferences       UserPreference?
  savedProperties   UserSavedProperty[]

  @@map("account")
}

model User {
  id          String    @id @default(cuid())
  name        String
  email       Json?     // Array of { type, value }
  phone       Json?     // Array of { type, value }
  location    String?
  role        String?   // Admin | Agent | User
  lastLogin   DateTime?
  avatarUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([role])
  @@index([lastLogin])
  @@map("users")
}

// ============================================================================
// Messaging & Communication
// ============================================================================

model Conversation {
  id                    String    @id @default(cuid())
  accountId             String?
  customerName          String
  customerPhone         String
  customerEmail         String?
  customerAvatarUrl     String?
  notes                 String?
  assignedTo            String    @default("AI Assistant")
  subject               String
  lastMessageAt         DateTime  @default(now())
  lastMessageSnippet    String?
  lastMessageSender     String    @default("agent") // agent | customer
  isRead                Boolean   @default(true)
  leadCategory          String    @default("New Inquiry") // New Inquiry | Follow-up | Negotiation | General Question | Other
  leadScore             Int       @default(5) // 1-10
  aiInterventionActive  Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  account               Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  messages              Message[]

  @@index([accountId])
  @@index([customerPhone])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id                String    @id @default(cuid())
  conversationId    String
  sender            String    // agent | customer
  text              String
  timestamp         DateTime  @default(now())

  // Relations
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([timestamp])
  @@map("messages")
}

model SiteContent {
  id        String    @id @default(cuid())
  key       String    @unique
  value     String
  section   String?   // footer | header | about | home | etc.
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([section])
  @@map("site_content")
}

// ============================================================================
// User Activity & Preferences
// ============================================================================

model Activity {
  id          String    @id @default(cuid())
  accountId   String
  activity    String    // page_view | save_property | view | save | share | call | inquiry | visit_request | mortgage_request
  page        String?
  propertyId  String?
  activityOn  DateTime  @default(now())
  duration    Int?      // in seconds

  // Relations
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([activityOn])
  @@index([propertyId])
  @@map("activities")
}

model UserPreference {
  id                        String    @id @default(cuid())
  accountId                 String    @unique
  updatedAt                 DateTime  @updatedAt
  
  // Preference aggregates (flexible JSON structure)
  preferences               Json      @default("{}")
  
  // Counters
  totalViews                Int       @default(0)
  totalSaves                Int       @default(0)
  totalCalls                Int       @default(0)
  totalInquiries            Int       @default(0)
  totalVisitRequests        Int       @default(0)
  totalMortgageRequests     Int       @default(0)
  totalShares               Int       @default(0)
  totalTimeSpentInSeconds   Int       @default(0)

  // Relations
  account                   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("user_preferences")
}

// ============================================================================
// Requests & Inquiries
// ============================================================================

model PropertyRequest {
  id            String    @id @default(cuid())
  name          String
  email         String
  phone         String?
  location      String?
  propertyType  String?
  bedrooms      Int?
  bathrooms     Int?
  budget        Int?
  remarks       String?
  status        String    @default("new") // new | contacted | closed
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("property_requests")
}

model MortgageRequest {
  id              String    @id @default(cuid())
  name            String
  email           String
  phone           String
  address         String
  age             Int
  income          Int
  moreDetails     String?
  contactMethods  String[]  @default([]) // call | email | whatsapp
  status          String    @default("new") // new | contacted | in-progress | closed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("mortgage_requests")
}

model SalesRequest {
  id                String    @id @default(cuid())
  name              String
  email             String
  phone             String
  propertyLocation  String
  propertyType      String
  remarks           String?
  status            String    @default("new") // new | contacted | closed
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("sales_requests")
}

model VisitRequest {
  id              String    @id @default(cuid())
  propertyId      String
  propertyTitle   String
  agentId         String
  agentName       String
  name            String
  email           String
  phone           String?
  preferredDate   String    // YYYY-MM-DD
  preferredTime   String?   // HH:mm
  status          String    @default("new") // new | confirmed | completed | cancelled
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([propertyId])
  @@index([agentId])
  @@index([status])
  @@index([createdAt])
  @@map("visit_requests")
}

// ============================================================================
// Error & System Logging
// ============================================================================

model Problem {
  id        String    @id @default(cuid())
  context   String
  message   String
  stack     String?
  details   Json?
  createdAt DateTime  @default(now())

  @@index([createdAt])
  @@map("problems")
}

// ============================================================================
// Newsletter
// ============================================================================

model NewsletterSubscription {
  id        String    @id @default(cuid())
  email     String    @unique
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("newsletter_subscriptions")
}

// ============================================================================
// Sitemaps & SEO
// ============================================================================

model SitemapEntry {
  id        String    @id @default(cuid())
  url       String    @unique
  priority  Float     @default(0.5)
  frequency String    @default("weekly") // always | hourly | daily | weekly | monthly | yearly | never
  lastmod   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([url])
  @@map("sitemaps")
}

// ============================================================================
// AI Configuration
// ============================================================================

model AIModel {
  id                           String   @id @default(cuid())
  modelId                      String
  name                         String
  description                  String?
  costPerMillionInputTokens    Float    @default(0)
  costPerMillionOutputTokens   Float    @default(0)
  isDefault                    Boolean  @default(false)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@index([isDefault])
  @@map("ai_models")
}

model Prompt {
  id           String   @id
  promptText   String
  description  String
  name         String
  placeholders String[] @default([])
  model        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("prompts")
}

// ============================================================================
// WhatsApp Integration
// ============================================================================

model WhatsAppConfig {
  id                 String   @id
  apiToken           String?
  phoneNumberId      String?
  accountId          String?
  webhookVerifyToken String?
  updatedAt          DateTime @updatedAt

  @@map("whatsapp_config")
}

model WhatsAppTemplate {
  id            String   @id @default(cuid())
  name          String
  category      String
  language      String
  body          String
  status        String
  isPreapproved Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("whatsapp_templates")
}

// ============================================================================
// Contact & Inquiry
// ============================================================================

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  body      String
  status    String   @default("new")
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("contact_submissions")
}

model Inquiry {
  id            String   @id @default(cuid())
  propertyId    String
  propertyTitle String
  agentName     String?
  name          String
  email         String
  phone         String?
  question      String
  status        String   @default("new")
  createdAt     DateTime @default(now())

  @@index([propertyId])
  @@index([status])
  @@index([createdAt])
  @@map("inquiries")
}

// ============================================================================
// Property Catalog
// ============================================================================

model Property {
  id                String    @id @default(cuid())
  title             String?
  description       String?
  price             Int?
  location          String?
  bedrooms          Int?
  bathrooms         Int?
  area              Float?
  areaUnit          String?
  facing            String?
  buildStart        Int?
  buildCompleted    Int?
  purpose           String?
  purposes          String[]  @default([])
  category          String?
  type              String?
  images            String[]  @default([])
  amenities         String[]  @default([])
  agency            Json?
  listingAgent      String?
  isOwnerListing    Boolean   @default(false)
  isFeatured        Boolean   @default(false)
  isApproved        Boolean   @default(false)
  status            String?   @default("pending")
  sourceUrl         String?
  slug              String?   @unique
  floors            Int?
  onFloor           Int?
  roadAccess        Float?
  latitude          Float?
  longitude         Float?
  fetchHistory      Json?
  imageFetchHistory Json?
  kitchens          Int?
  diningRooms       Int?
  livingRooms       Int?
  carParkingSpots   Int?
  bikeParkingSpots  Int?
  metaTitle         String?
  metaDescription   String?
  metaTags          String[]  @default([])
  landDetails       Json?
  plots             Json?
  apartmentDetails  Json?
  apartmentUnits    Json?
  structuredLocation Json?
  pricing           Json?
  roadAccessDetails Json?
  distancing        Json?
  earnings          Json?
  owner             Json?
  owners            Json?
  documents         Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  savedBy           UserSavedProperty[]

  @@index([price])
  @@index([location])
  @@index([purpose])
  @@index([category])
  @@index([type])
  @@index([slug])
  @@index([sourceUrl])
  @@map("properties")
}

// ============================================================================
// Agency, Agent, Team, Reviews
// ============================================================================

model Agency {
  id                String   @id @default(cuid())
  name              String
  logoUrl           String?
  website           String?
  registeredName    String?
  contactEmail      String?
  contactPhone      String?
  mainLocation      String?
  branches          String[] @default([])
  contactPersonName String?
  contactPersonRole String?
  description       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([name])
  @@map("agencies")
}

model Agent {
  id                String   @id @default(cuid())
  name              String
  slug              String?  @unique
  location          String?
  registered        Boolean  @default(false)
  userId            String?
  email             String?
  phone             String?
  about             String?
  photoUrl          String?
  specializations   String[] @default([])
  availabilityHours String?
  timeSlotDuration  Int?
  unavailability    Json?
  agencyId          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([agencyId])
  @@index([slug])
  @@map("agents")
}

model TeamMember {
  id          String   @id @default(cuid())
  orgId       String?
  userId      String?
  name        String
  slug        String?  @unique
  position    String
  socialMedia Json?
  about       String
  moreDetails String?
  photoUrl    String?
  registered  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@map("team_members")
}

model Review {
  id          String   @id @default(cuid())
  targetId    String
  targetType  String
  targetName  String
  authorName  String
  authorEmail String?
  rating      Int
  reviewText  String
  createdAt   DateTime @default(now())

  @@index([targetId])
  @@index([targetType])
  @@index([createdAt])
  @@map("reviews")
}

// ============================================================================
// Requirements
// ============================================================================

model Requirement {
  id              String    @id @default(cuid())
  userId          String
  minBudget       Int?
  maxBudget       Int?
  location        String?
  propertyType    String[]  @default([])
  purpose         String?   // 'Sale' | 'Rent' | 'Lease'
  urgency         String?   // 'within a month' | 'within 3 months' | etc.
  requiredTime    String?   // same as urgency
  paymentMethod   String[]  @default([])
  loan            Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@map("requirements")
}

// ============================================================================
// Saved Properties
// ============================================================================

model UserSavedProperty {
  userId        String
  propertyId    String
  propertyTitle String?
  savedAt       DateTime @default(now())

  account       Account  @relation(fields: [userId], references: [id], onDelete: Cascade)
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([userId, propertyId])
  @@index([savedAt])
  @@index([propertyId])
  @@map("user_saved_properties")
}
